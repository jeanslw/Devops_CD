# CD Service 配置
# 复制为 .env 并修改下方的值

# ── 数据库（推荐 MySQL / MariaDB，和 PHP 端共用 devops_glue 库）──
# MySQL / MariaDB 模式：填下面 5 项
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devops_glue
DB_USER=YOUR_MYSQL_USER
DB_PASS=YOUR_MYSQL_PASSWORD

# SQLite 模式（可选）：注释上面 MySQL 配置，启用下面两行
# DB_DRIVER=sqlite
# DB_PATH=../Devops-Glue/config/data/data.db

# ═══════════════════════════════════════
# 必填 — Harbor 镜像仓库
# ═══════════════════════════════════════
HARBOR_REGISTRY=your_harbor_address
HARBOR_USER=your_harbor_user
HARBOR_PASSWORD=your_harbor_password

# ═══════════════════════════════════════
# 可选 — 以下有合理默认值，一般无需修改
# ═══════════════════════════════════════
# HOST=0.0.0.0
# PORT=8081
# SSH_TIMEOUT=30
# CONTAINER_RESTART_POLICY=always
# LOG_TRUNCATE_CHARS=2000
# NOTIFY_TRUNCATE_CHARS=200
# DINGTALK_SECRET=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MONITORING_ENABLED=true
# MONITOR_CACHE_SERVERS=60
# MONITOR_CACHE_SYSTEM=30
# MONITOR_CACHE_NODES=30
# MONITOR_CACHE_PODS=30
# MONITOR_CACHE_DOCKER=30
# MONITOR_CACHE_POD_DETAIL=15
